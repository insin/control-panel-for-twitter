{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "homepage_url": "https://soitis.dev/control-panel-for-twitter",
  "version": "5.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "64": "icons/icon64.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["alarms", "storage"],
  "host_permissions": ["https://pro.soitis.dev/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "world": "MAIN",
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["script.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://pro.soitis.dev/*"],
      "js": ["content-pro.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["extensions-pro-id.js", "settings.js"],
      "matches": ["https://pro.soitis.dev/*", "https://twitter.com/*", "https://x.com/*"]
    }
  ],
  "options_ui": {
    "page": "options.html"
  },
  "action": {
    "default_title": "__MSG_extensionName__",
    "default_popup": "browser_action.html"
  }
}
